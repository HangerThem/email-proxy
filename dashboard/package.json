{
  "name": "dashboard",
  "version": "1.0.0",
  "description": "Multi-tenant Email API proxy server dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch & tailwindcss -i ./src/style/global.css -o ./_site/style/global.css --watch & eleventy --formats=11ty.jsx,11ty.tsx --serve",
    "build": "vite build && tailwindcss -i ./src/style/global.css -o ./_site/style/global.css --minify && eleventy --formats=11ty.jsx,11ty.tsx"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@floating-ui/react": "^0.27.19",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}