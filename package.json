{
  "name": "email-proxy-server",
  "version": "1.0.0",
  "description": "Multi-tenant Email API proxy server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "nodemon --watch src --ext ts --exec \"tsc -p tsconfig.json && node dist/index.js\"",
    "start:dev": "nodemon --watch src --ext ts --exec \"tsc -p tsconfig.json && node dist/index.js\"",
    "start:prod": "node dist/index.js",
    "migrate": "tsc -p tsconfig.json && node dist/migrate.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^11.0.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
